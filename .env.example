DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
FRONTEND_URL="http://localhost:3000"
JWT_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="935612449747-ik7b4glq6ritqs6oa6jg2l0gni270esc.apps.googleusercontent.com"

# Sessions expire after 1 hour of inactivity by default.
AUTH_IDLE_TIMEOUT_HOURS=1
JWT_ACCESS_TOKEN_MAX_AGE="6h"

# Password reset delivery through Brevo SMTP.
# SMTP_PASS is the SMTP key generated in Brevo, not your Brevo login password.
# MAIL_FROM must be a sender address authorized in your Brevo account.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-brevo-smtp-login@smtp-brevo.com"
SMTP_PASS="your-brevo-smtp-key"
MAIL_FROM="Lahan Project Management <verified-sender@example.com>"
# Optional: stop a stalled SMTP connection from delaying forgot-password.
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
