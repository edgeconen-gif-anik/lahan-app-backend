DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
FRONTEND_URL="http://localhost:3000"
JWT_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# Sessions expire after 1 hour of inactivity by default.
AUTH_IDLE_TIMEOUT_HOURS=1
JWT_ACCESS_TOKEN_MAX_AGE="6h"

# Free SMTP option: Gmail with a Google App Password.
# You can also use any free SMTP provider by changing host/port/user/pass.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-google-app-password"
MAIL_FROM="Lahan Project Management <your-email@gmail.com>"
